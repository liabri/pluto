# HTTP to HTTPS redirection
#http:// {
#	redir https://{host}{uri} permanent
#}

{
	http_port 80
	https_port 443
	admin off

	layer4 {
		:25565 {
			route {
				proxy {
					upstream 172.16.5.1:25565
				}	
			}
		}
	}
}

:80 {
	# uri strip_suffix "/" 

	# git-web
	redir /git/ /git
	handle /git* {
#		rewrite * /cgit.cgi{uri}
		reverse_proxy http://172.16.4.1:8080
	}

	# lbmt-darkroom
	reverse_proxy http://172.16.1.1:8080
}

:443 {
	tls internal
	respond "BOO!"
}

